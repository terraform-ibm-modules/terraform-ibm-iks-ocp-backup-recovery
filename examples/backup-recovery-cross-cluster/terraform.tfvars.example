##############################################################################
# Example terraform.tfvars
# Copy this file to terraform.tfvars and fill in your values
##############################################################################

# IBM Cloud API Key (required)
ibmcloud_api_key = "YOUR_IBM_CLOUD_API_KEY_HERE"  # pragma: allowlist secret

# Prefix for resource names
prefix = "backup-recovery-test"

# IBM Cloud region
region = "us-south"

# Existing resource group name (optional - will create new if null)
resource_group = null

# Resource tags
resource_tags = ["terraform", "backup-recovery-example", "cross-cluster"]

# Access tags (optional)
access_tags = []

##############################################################################
# Cluster Configuration
##############################################################################

# Use existing clusters (optional - will create new if null)
source_cluster_name_id = null  # e.g., "my-source-cluster"
target_cluster_name_id = null  # e.g., "my-target-cluster"

##############################################################################
# BRS Instance Configuration
##############################################################################

# Use existing BRS instance (optional - will create new if null)
existing_brs_instance_crn = null  # e.g., "crn:v1:bluemix:public:backup-recovery:us-south:a/abc123:def456::"

##############################################################################
# Recovery Configuration
##############################################################################

# Enable automatic recovery after backup completes
# Set to false for backup-only testing
enable_recovery = true

# Recovery mode: "same-cluster" or "cross-cluster"
# Use "cross-cluster" to test recovery to target cluster
recovery_mode = "cross-cluster"

# Wait time in minutes for initial backup to complete
# Increase for larger clusters or slower networks
wait_for_backup_completion = 30
